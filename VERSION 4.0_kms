def main():
    print("=" * 62)
    print("  통화 완화 환경에서의 자산군별 가격 반응 시차 실증 분석")
    print("  ★ VERSION 4.0 — M2 YoY + 분류기 방향 우선 앙상블")
    print("=" * 62)

    # 한글 폰트
    system = platform.system()
    if system == "Windows":
        plt.rcParams["font.family"] = "Malgun Gothic"
    elif system == "Darwin":
        plt.rcParams["font.family"] = "AppleGothic"
    plt.rcParams["axes.unicode_minus"] = False

    # ── STEP 1~5 ────────────────────────────────────────────
    df_raw = load_all_data()
    df_raw.to_csv(f"{CONFIG['OUT_DIR']}/raw_data.csv")

    df = preprocess(df_raw)
    df = build_monetary_vars(df)
    df = add_rate_cycle_dummies(df)
    df = build_features(df)
    df.to_csv(f"{CONFIG['OUT_DIR']}/processed_data.csv")

    # ── STEP 6: 그랜저 + 시각화 ─────────────────────────────
    causality_df, lag_table = run_granger_analysis(df)
    if not causality_df.empty:
        causality_df.to_csv(f"{CONFIG['OUT_DIR']}/granger.csv",
                            index=False)

    print("\n[시각화] 칸티용 효과 전이경로 맵")
    plot_cantillon_path(df, lag_table)
    plot_m2_vs_assets(df)
    plot_asset_response_timeline(df)
    plot_easing_cycle_overlay(df)

    # ── STEP 7~: 자산별 모델 학습 ───────────────────────────
    target_map = {
        "Gold":        "Gold_LogReturn",
        "WTI":         "WTI_LogReturn",
        "SP500":       "SP500_LogReturn",
        "CaseShiller": "CaseShiller_LogReturn",
        "CPI":         "CPI_LogReturn",
    }

    dummy_cols = ["Cut_Start","Cut_Period","Hike_Start","Easing_Period"]
    monetary_lag_cols = [c for c in df.columns if any(
        k in c for k in CONFIG["MONETARY_VARS"]
    ) and "lag" in c]

    all_metrics = {}

    for asset_name, target_col in target_map.items():
        if target_col not in df.columns:
            print(f"\n  ⚠️  {target_col} 없음")
            continue

        print(f"\n{'='*62}")
        print(f"  ▶ 자산: {asset_name}  ({target_col})")
        print("=" * 62)

        # 피처 구성 (자산별 그랜저 맞춤 시차 포함)
        granger_cols = [c for c in df.columns
                        if f"granger_{asset_name}" in c]
        feat_cols = list(dict.fromkeys(
            monetary_lag_cols +
            [c for c in df.columns if asset_name in c
             and ("lag" in c or "RSI" in c or "MACD" in c
                  or "Mom" in c or "MA" in c)] +
            [c for c in df.columns if "M2_YoY_lag" in c] +
            [c for c in df.columns if "Cross_" in c] +
            granger_cols + dummy_cols
        ))
        feat_cols = [c for c in feat_cols
                     if c in df.columns and c != target_col]

        data = df[[target_col] + feat_cols].dropna()
        if len(data) < CONFIG["MIN_TRAIN"] + 30:
            print(f"  ⚠️  데이터 부족 ({len(data)}개)")
            continue

        X_all = data[feat_cols]
        y_all = data[target_col]
        n     = len(data)
        tr_end  = int(n * 0.70)
        val_end = int(n * 0.85)

        X_tr  = X_all.iloc[:tr_end];       y_tr  = y_all.iloc[:tr_end]
        X_val = X_all.iloc[tr_end:val_end];y_val = y_all.iloc[tr_end:val_end]
        X_te  = X_all.iloc[val_end:];      y_te  = y_all.iloc[val_end:]

        print(f"  학습: {len(X_tr)}  검증: {len(X_val)}  테스트: {len(X_te)}")

        # 스케일링
        sx = StandardScaler(); sy = StandardScaler()
        X_tr_s  = pd.DataFrame(sx.fit_transform(X_tr),
                               columns=feat_cols, index=X_tr.index)
        X_val_s = pd.DataFrame(sx.transform(X_val),
                               columns=feat_cols, index=X_val.index)
        X_te_s  = pd.DataFrame(sx.transform(X_te),
                               columns=feat_cols, index=X_te.index)
        y_tr_s  = sy.fit_transform(y_tr.values.reshape(-1,1)).flatten()
        y_val_s = sy.transform(y_val.values.reshape(-1,1)).flatten()
        y_te_s  = sy.transform(y_te.values.reshape(-1,1)).flatten()

        # 피처 선택
        top_feats = select_top_features(X_tr_s, y_tr_s)
        Xtr_sel   = X_tr_s[top_feats]
        Xval_sel  = X_val_s[top_feats]
        Xte_sel   = X_te_s[top_feats]

        # Optuna 튜닝
        best_params = optuna_tune(Xtr_sel, y_tr_s, Xval_sel, y_val_s)

        # XGBoost 회귀
        print(f"\n  🌲 XGBoost 회귀")
        xgb_reg = train_xgb_reg(Xtr_sel, y_tr_s, Xval_sel, y_val_s,
                                 best_params)
        xgb_reg_pred = sy.inverse_transform(
            xgb_reg.predict(Xte_sel).reshape(-1,1)).flatten()
        m = compute_metrics(y_te.values, xgb_reg_pred)
        print_metrics(m, f"{asset_name} - XGBoost 회귀")
        all_metrics[f"{asset_name}_XGB_Reg"] = m

        # XGBoost 분류
        print(f"\n   XGBoost 분류 (방향성)")
        xgb_clf = train_xgb_clf(Xtr_sel, y_tr_s, Xval_sel, y_val_s)
        clf_probs   = xgb_clf.predict_proba(Xte_sel)[:, 1]
        clf_dir_acc = accuracy_score(
            (y_te.values > 0).astype(int),
            (clf_probs > 0.5).astype(int)) * 100
        print(f"    ✓ XGBoost 분류 방향성: {clf_dir_acc:.1f}%")
        all_metrics[f"{asset_name}_XGB_Clf"] = {
            "Dir_Acc": clf_dir_acc, "MAE": 0,
            "RMSE": 0, "sMAPE": 0, "R2": 0
        }

        # LightGBM
        print(f"\n  ⚡ LightGBM 회귀")
        lgb_reg = train_lgb_reg(Xtr_sel, y_tr_s, Xval_sel, y_val_s)
        lgb_reg_pred = sy.inverse_transform(
            lgb_reg.predict(Xte_sel).reshape(-1,1)).flatten()
        m = compute_metrics(y_te.values, lgb_reg_pred)
        print_metrics(m, f"{asset_name} - LightGBM 회귀")
        all_metrics[f"{asset_name}_LGB_Reg"] = m

        print(f"\n   LightGBM 분류")
        lgb_clf = train_lgb_clf(Xtr_sel, y_tr_s, Xval_sel, y_val_s)

        # ★ v4 앙상블 (분류기 방향 100% 우선)
        print(f"\n  🔗 v4 앙상블 (분류기 방향 100% 우선)")
        ens_preds, ens_probs = ensemble_predict_v4(
            [xgb_reg, lgb_reg], [xgb_clf, lgb_clf], Xte_sel, sy)
        m = compute_metrics(y_te.values, ens_preds)
        print_metrics(m, f"{asset_name} - v4 앙상블 (최종)")
        all_metrics[f"{asset_name}_Ensemble"] = m

        # SHAP
        run_shap(xgb_reg, Xte_sel, asset_name, "XGB")

        # Walk-forward
        print(f"\n   Walk-forward: {asset_name}")
        bt = walk_forward(Xtr_sel,
                          pd.Series(y_tr_s, index=Xtr_sel.index))
        plot_backtest(bt, asset_name)
        all_metrics[f"{asset_name}_WF"] = bt["avg_metrics"]

        # BiGRU (보조)
        feat_deep = top_feats[:20]
        X_deep = np.vstack([X_tr_s[feat_deep].values,
                            X_val_s[feat_deep].values])
        y_deep = np.concatenate([y_tr_s, y_val_s])
        lb = CONFIG["LOOKBACK"]

        if len(X_deep) > lb + 30:
            print(f"\n   BiGRU (보조): {asset_name}")
            sp = int(len(X_deep) * 0.85)
            gru_model, _ = train_bigru_pytorch(
                X_deep[:sp], y_deep[:sp],
                X_deep[sp:], y_deep[sp:])

            if gru_model is not None:
                X_te_deep = np.vstack([
                    X_tr_s[feat_deep].values[-lb:],
                    X_te_s[feat_deep].values])
                gru_raw  = predict_bigru(gru_model, X_te_deep, lb)
                gru_pred = sy.inverse_transform(
                    gru_raw.reshape(-1,1)).flatten()
                gru_act  = y_te.values[-len(gru_pred):]
                if len(gru_pred) > 0:
                    gru_m = compute_metrics(gru_act, gru_pred)
                    print_metrics(gru_m,
                                  f"{asset_name} - BiGRU (보조)")
                    all_metrics[f"{asset_name}_BiGRU"] = gru_m

    # ── 최종 비교 ────────────────────────────────────────────
    print("\n[최종] 전체 모델 성능 비교")
    if all_metrics:
        compare_models(all_metrics)

    # ── 리포트 ───────────────────────────────────────────────
    print("\n[최종] 리포트 생성")
    generate_html_report(df, all_metrics)

    # ── 한국 검증 ────────────────────────────────────────────
    validate_korea()

    print("\n" + "=" * 62)
    print("   v4 파이프라인 완료!")
    print(f"  결과: {CONFIG['OUT_DIR']}/report_v4.html")
    print("=" * 62)

    return df, all_metrics


if __name__ == "__main__":
    df_result, metrics_result = main()
