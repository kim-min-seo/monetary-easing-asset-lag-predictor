def plot_asset_response_timeline(df):
    asset_lr_cols = {
        "Gold":    "Gold_LogReturn",
        "WTI":     "WTI_LogReturn",
        "S&P500":  "SP500_LogReturn",
        "부동산":   "CaseShiller_LogReturn",
        "CPI":     "CPI_LogReturn",
    }
    colors = ["#f1c40f","#e67e22","#2ecc71","#e74c3c","#9b59b6"]
    fig, ax = plt.subplots(figsize=(14,7))
    event_months = 36

    cut_start = pd.Timestamp("2007-09-01")
    valid = df.index[df.index >= cut_start]
    if len(valid) > 0:
        cut_start = valid[0]
        idx = df.index.get_loc(cut_start)
        for (label, col), color in zip(asset_lr_cols.items(), colors):
            if col not in df.columns: continue
            end_idx = min(idx + event_months, len(df))
            series  = df[col].iloc[idx:end_idx]
            cumret  = (1 + series).cumprod() - 1
            ax.plot(range(len(cumret)), cumret*100,
                    label=label, color=color, lw=2.5)

    ax.axvline(0, color="black", lw=2, ls="--", label="금리인하 시작")
    ax.axhline(0, color="gray",  lw=1, ls=":")
    ax.set_xlabel("금리인하 후 경과 개월"); ax.set_ylabel("누적 수익률 (%)")
    ax.set_title("금리인하 후 자산군별 누적 반응 (2007년 사이클)",
                 fontsize=13, fontweight="bold")
    ax.legend(); ax.grid(True, alpha=0.3)
    plt.tight_layout()
    path = f"{CONFIG['OUT_DIR']}/asset_response_timeline.png"
    plt.savefig(path, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  ✓ 자산 반응 타임라인 저장")


