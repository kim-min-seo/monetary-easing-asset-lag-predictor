    assets   = ["Gold","WTI","SP500","CaseShiller"]
    colors_a = ["gold","orangered","green","brown"]
    assets_in = [a for a in assets if a in df.columns]

    fig, axes = plt.subplots(len(assets_in), 1,
                             figsize=(14, 4*len(assets_in)),
                             sharex=True)
