# ============================================================
# SECTION 1 : 샘플 데이터 생성기
# ============================================================

def generate_sample_data(n=300):
    print("  📝 샘플 데이터 생성 (테스트 모드)...")
    dates = pd.date_range(start=CONFIG["START_DATE"], periods=n, freq="MS")
    rng   = np.random.default_rng(42)

    fed_rate = np.zeros(n)
    fed_rate[:50]    = 5.5
    fed_rate[50:80]  = np.linspace(5.5, 1.0, 30)
    fed_rate[80:130] = 1.0
    fed_rate[130:160]= np.linspace(1.0, 5.25, 30)
    fed_rate[160:190]= np.linspace(5.25, 0.25, 30)
    fed_rate[190:240]= 0.25
    fed_rate[240:260]= np.linspace(0.25, 2.5, 20)
    fed_rate[260:270]= np.linspace(2.5, 1.75, 10)
    fed_rate[270:280]= np.linspace(1.75, 0.25, 10)
    fed_rate[280:]   = np.linspace(0.25, 4.5, n-280)
    fed_rate += rng.standard_normal(n) * 0.1

    fed_chg  = np.diff(fed_rate, prepend=fed_rate[0])
    cpi_base = 100 * np.exp(np.cumsum(0.002 - fed_chg*0.1 +
                                       rng.standard_normal(n)*0.003))
    real_rate  = fed_rate - np.gradient(cpi_base)/cpi_base*100
    fed_assets = 800 + np.cumsum(np.maximum(-fed_chg*500,0)) + \
                 rng.standard_normal(n)*50
    dxy  = 100 - fed_rate*2 + rng.standard_normal(n)*3
    m2   = 7000 * np.exp(np.cumsum(-fed_chg*0.05 + 0.003))
    gdp  = 10000* np.exp(np.cumsum(0.004 + rng.standard_normal(n)*0.008))

    mon  = -fed_chg
    gold_r = np.roll(mon,10)*2.0 + rng.standard_normal(n)*0.03
    wti_r  = np.roll(mon,4) *2.5 + rng.standard_normal(n)*0.05
    sp_r   = np.roll(mon,1) *3.0 + rng.standard_normal(n)*0.04
    cs_r   = np.roll(mon,11)*1.5 + rng.standard_normal(n)*0.02

    df = pd.DataFrame({
        "FedRate":    fed_rate,
        "Fed_Assets": fed_assets,
        "T10Y":       fed_rate+1.5+rng.standard_normal(n)*0.3,
        "T2Y":        fed_rate+0.5+rng.standard_normal(n)*0.2,
        "CPI":        cpi_base,
        "M2":         m2,
        "GDP":        gdp,
        "CaseShiller":100*np.exp(np.cumsum(cs_r*0.01)),
        "Gold":       400*np.exp(np.cumsum(gold_r*0.01)),
        "WTI":        40 *np.exp(np.cumsum(wti_r*0.01)),
        "DXY":        dxy,
        "SP500":      1000*np.exp(np.cumsum(sp_r*0.01)),
    }, index=dates)

    print(f"  ✓ 완료: {df.shape[0]}개월 × {df.shape[1]}개 변수")
    return df


# ============================================================
# SECTION 2 : 데이터 수집
# ============================================================

def collect_fred_data():
    try:
        from fredapi import Fred
    except ImportError:
        return None

    print("  📊 FRED 데이터 수집 중...")
    fred = Fred(api_key=CONFIG["FRED_API_KEY"])
    data = {}

    for name, sid in FRED_SERIES.items():
        try:
            s = fred.get_series(sid,
                                observation_start=CONFIG["START_DATE"],
                                observation_end=CONFIG["END_DATE"])
            data[name] = s
            print(f"    ✓ {name} ({sid}): {len(s)}개")
        except Exception as e:
            print(f"    ✗ {name}: {e}")

    df = pd.DataFrame(data)
    df.index = pd.to_datetime(df.index)
    return df.resample("MS").last()


def collect_yahoo_data():
    try:
        import yfinance as yf
    except ImportError:
        return None

    print("  📈 Yahoo Finance 데이터 수집 중...")
    data = {}

    for name, ticker in YAHOO_TICKERS.items():
        try:
            raw = yf.download(ticker,
                              start=CONFIG["START_DATE"],
                              end=CONFIG["END_DATE"],
                              interval="1mo",
                              progress=False,
                              auto_adjust=True)
            if raw.empty:
                continue
            if isinstance(raw.columns, pd.MultiIndex):
                raw.columns = raw.columns.get_level_values(0)
            s = raw["Close"].squeeze()
            if isinstance(s, pd.Series) and len(s) > 0:
                s.name = name
                data[name] = s
                print(f"    ✓ {name} ({ticker}): {len(s)}개")
        except Exception as e:
            print(f"    ✗ {name}: {e}")

    if not data:
        return None
    df = pd.DataFrame(data)
    df.index = pd.to_datetime(df.index)
    return df.resample("MS").last()


def load_all_data():
    print("\n[STEP 1] 데이터 수집")
    use_sample = CONFIG["FRED_API_KEY"] in ["your_fred_api_key_here", ""]

    if use_sample:
        print("  ℹ️  샘플 데이터 사용")
        return generate_sample_data()

    df_fred  = collect_fred_data()
    df_yahoo = collect_yahoo_data()

    frames = [f for f in [df_fred, df_yahoo] if f is not None]
    if not frames:
        return generate_sample_data()

    df = pd.concat(frames, axis=1).sort_index()
    df = df.loc[~df.index.duplicated(keep="first")]
    print(f"\n   병합 완료: {df.shape[0]}개월 × {df.shape[1]}개 변수")
    print(f"     기간: {df.index[0].strftime('%Y-%m')} ~ "
          f"{df.index[-1].strftime('%Y-%m')}")
    return df


# ============================================================
# SECTION 3 : 전처리
# ============================================================

def preprocess(df):
    print("\n[STEP 2] 전처리")
    df = df.interpolate(method="linear",
                        limit_direction="both").ffill().bfill()

    price_cols = ["Gold","WTI","SP500","CaseShiller","CPI"]
    for col in price_cols:
        if col in df.columns and (df[col] > 0).all():
            df[f"{col}_LogReturn"] = np.log(df[col] / df[col].shift(1))
            df[f"{col}_YoY"]       = df[col].pct_change(12) * 100

    print(f"  ✓ 결측치: {df.isnull().sum().sum()}개")
    print(f"  ✓ 컬럼 수: {df.shape[1]}")
    return df


# ============================================================
# SECTION 4 : 통화환경 독립변수 구성 (★ v4: M2 YoY 추가)
# ============================================================

def build_monetary_vars(df):
    print("\n[STEP 3] 통화환경 독립변수 구성")

    # 1. 금리변화율
    if "FedRate" in df.columns:
        df["FedRate_Change"]   = df["FedRate"].diff()
        df["FedRate_Change3M"] = df["FedRate"].diff(3)
        df["FedRate_Change12M"]= df["FedRate"].diff(12)
        print("  ✓ 금리변화율 생성")

    # 2. 실질금리
    if "FedRate" in df.columns and "CPI_YoY" in df.columns:
        df["Real_Rate"]   = df["FedRate"] - df["CPI_YoY"]
        df["NegRealRate"] = (df["Real_Rate"] < 0).astype(int)
        print("  ✓ 실질금리 생성")

    # 3. QE 규모
    if "Fed_Assets" in df.columns:
        df["QE_Size"]   = df["Fed_Assets"].pct_change() * 100
        df["QE_Active"] = (df["QE_Size"] > 0).astype(int)
        print("  ✓ QE 규모 생성")
    elif "QE_Size" not in df.columns:
        df["QE_Size"] = 0.0

    # 4. 달러인덱스 변화율
    if "DXY" in df.columns:
        df["DXY_Change"] = df["DXY"].pct_change()  * 100
        df["DXY_YoY"]   = df["DXY"].pct_change(12) * 100
        print("  ✓ 달러인덱스 변화율 생성")

    # 5. 수익률 곡선
    if "T10Y" in df.columns and "T2Y" in df.columns:
        df["Yield_Spread"]    = df["T10Y"] - df["T2Y"]
        df["YieldCurve_Inv"]  = (df["Yield_Spread"] < 0).astype(int)
        print("  ✓ 수익률 곡선 생성")

    # 6. 초과유동성
    if "M2" in df.columns and "GDP" in df.columns:
        m2g  = df["M2"].pct_change(12) * 100
        gdpg = df["GDP"].pct_change(4) * 100
        df["Excess_Liquidity"] = m2g - gdpg
        print("  ✓ 초과유동성 생성")

    # ★ v4: M2 전년비 증가율 추가 (팀 요청)
    if "M2" in df.columns:
        df["M2_YoY"]   = df["M2"].pct_change(12) * 100   # 전년비 증가율
        df["M2_MoM"]   = df["M2"].pct_change(1)  * 100   # 전월비 증가율
        df["M2_Accel"] = df["M2_YoY"].diff()              # M2 증가율 가속도
        df["M2_High"]  = (df["M2_YoY"] > df["M2_YoY"].rolling(24).mean()
                          ).astype(int)                    # 장기평균 대비 고성장
        print("  ✓ M2 전년비/전월비/가속도 생성 (★ v4 추가)")

    # 통화완화 종합지수
    signals = []
    if "NegRealRate"    in df.columns: signals.append(df["NegRealRate"])
    if "QE_Active"      in df.columns: signals.append(df["QE_Active"])
    if "YieldCurve_Inv" in df.columns: signals.append(df["YieldCurve_Inv"])
    if "FedRate_Change" in df.columns:
        signals.append((df["FedRate_Change"] < 0).astype(int))
    if "M2_High"        in df.columns: signals.append(df["M2_High"])
    if signals:
        df["Monetary_Ease_Index"] = sum(signals)
        print(f"  ✓ 통화완화 종합지수 생성 (0~{len(signals)}점)")

    return df


# ============================================================
# SECTION 5 : 금리인하 사이클 더미변수 (3단계)
# ============================================================

def add_rate_cycle_dummies(df):
    print("\n[STEP 4] 금리인하 사이클 더미변수 (3단계)")

    df["Cut_Start"]  = 0
    df["Cut_Period"] = 0
    df["Hike_Start"] = 0

    for i, (start, end) in enumerate(CONFIG["RATE_CUT_CYCLES"]):
        s = pd.Timestamp(start)
        e = pd.Timestamp(end)

        cut_start_end = s + pd.DateOffset(months=3)
        df.loc[(df.index >= s) & (df.index < cut_start_end),
               "Cut_Start"] = 1
        df.loc[(df.index >= cut_start_end) & (df.index <= e),
               "Cut_Period"] = 1

        hike_end = e + pd.DateOffset(months=3)
        df.loc[(df.index >= e) & (df.index < hike_end),
               "Hike_Start"] = 1

        print(f"  ✓ 사이클 {i+1}: {start} ~ {end}")

    df["Easing_Period"] = (df["Cut_Start"] | df["Cut_Period"]).astype(int)
    print(f"  ✓ 완화 구간 총 {df['Easing_Period'].sum()}개월")
    return df


# ============================================================
# SECTION 6 : 피처 엔지니어링 (★ v4: 그랜저 시차 반영)
# ============================================================

def compute_rsi(series, period=14):
    delta = series.diff()
    gain  = delta.clip(lower=0).rolling(period).mean()
    loss  = (-delta.clip(upper=0)).rolling(period).mean()
    rs    = gain / (loss + 1e-8)
    return 100 - (100 / (1 + rs))


def compute_macd(series, fast=12, slow=26, signal=9):
    ema_f = series.ewm(span=fast, adjust=False).mean()
    ema_s = series.ewm(span=slow, adjust=False).mean()
    macd  = ema_f - ema_s
    sig   = macd.ewm(span=signal, adjust=False).mean()
    return macd, sig, macd - sig


def build_features(df):
    print("\n[STEP 5] 피처 엔지니어링 (v4 — 그랜저 시차 반영)")

    # 통화환경 변수 목록 (M2 YoY 포함)
    monetary_cols = [c for c in CONFIG["MONETARY_VARS"]
                     if c in df.columns]

    asset_price_cols = [c for c in
                        ["Gold","WTI","SP500","CaseShiller"]
                        if c in df.columns]
    asset_lr_cols    = [c for c in df.columns if "_LogReturn" in c]

    # ── 1. 통화환경 변수 시차 (일반)
    print("  → 통화환경 시차 변수 생성")
    for col in monetary_cols:
        for lag in CONFIG["LAG_PERIODS"]:
            df[f"{col}_lag{lag}"] = df[col].shift(lag)

    # ★ v4: 그랜저 결과 기반 자산별 맞춤 시차
    print("  → 그랜저 기반 맞춤 시차 생성")
    for asset, lags in CONFIG["ASSET_BEST_LAGS"].items():
        for col in monetary_cols:
            for lag in lags:
                key = f"{col}_granger_{asset}_lag{lag}"
                if col in df.columns:
                    df[key] = df[col].shift(lag)

    # ── 2. 자산 수익률 시차
    print("  → 자산 수익률 시차 생성")
    for col in asset_lr_cols:
        if col in df.columns:
            for lag in [1, 3, 6, 12]:
                df[f"{col}_lag{lag}"] = df[col].shift(lag)

    # ── 3. 이동평균
    print("  → 이동평균 생성")
    for col in asset_price_cols:
        if col in df.columns:
            for w in CONFIG["MA_WINDOWS"]:
                df[f"{col}_MA{w}"]  = df[col].rolling(w).mean()
                df[f"{col}_EMA{w}"] = df[col].ewm(span=w).mean()
            df[f"{col}_GoldenCross"] = (
                df[col].rolling(6).mean() >
                df[col].rolling(12).mean()
            ).astype(int)

    # ── 4. RSI + MACD
    print("  → RSI / MACD 생성")
    for col in asset_price_cols:
        if col in df.columns:
            df[f"{col}_RSI14"]     = compute_rsi(df[col], 14)
            df[f"{col}_OB"]        = (df[f"{col}_RSI14"] > 70).astype(int)
            df[f"{col}_OS"]        = (df[f"{col}_RSI14"] < 30).astype(int)
            macd, sig, hist        = compute_macd(df[col])
            df[f"{col}_MACD"]      = macd
            df[f"{col}_MACD_Hist"] = hist
            df[f"{col}_MACD_Bull"] = (macd > sig).astype(int)

    # ── 5. 변동성
    print("  → 변동성 생성")
    for col in asset_lr_cols:
        if col in df.columns:
            df[f"{col}_Vol6"]  = df[col].rolling(6).std()
            df[f"{col}_Vol12"] = df[col].rolling(12).std()

    # ── 6. 모멘텀
    print("  → 모멘텀 생성")
    for col in asset_price_cols:
        if col in df.columns:
            df[f"{col}_Mom3_12"] = (
                df[col].rolling(3).mean() /
                (df[col].rolling(12).mean() + 1e-8)
            )
            df[f"{col}_ROC6"]  = df[col].pct_change(6)  * 100
            df[f"{col}_ROC12"] = df[col].pct_change(12) * 100

    # ── 7. 교차 자산 시차 (칸티용 전이)
    print("  → 교차 자산 시차 생성")
    cantillon_pairs = [
        ("Gold_LogReturn",  "WTI_LogReturn"),
        ("Gold_LogReturn",  "SP500_LogReturn"),
        ("WTI_LogReturn",   "CPI_LogReturn"),
        ("SP500_LogReturn", "CaseShiller_LogReturn"),
    ]
    for src, tgt in cantillon_pairs:
        if src in df.columns and tgt in df.columns:
            for lag in [1, 3, 6, 12]:
                df[f"Cross_{src[:4]}_{tgt[:4]}_lag{lag}"] = \
                    df[src].shift(lag)

    # ── 8. M2 YoY 시차 (★ v4: 그랜저 검증용 핵심)
    print("  → M2 YoY 시차 생성 (★ v4)")
    if "M2_YoY" in df.columns:
        for lag in [1, 3, 6, 9, 12, 18, 24]:
            df[f"M2_YoY_lag{lag}"] = df["M2_YoY"].shift(lag)

    # 결측치 제거
    df = df.dropna(subset=[c for c in df.columns if "lag" in c][:3])
    print(f"  ✓ 최종 피처 수: {df.shape[1]}, 데이터: {df.shape[0]}개월")
    return df


# ============================================================
# SECTION 7 : 그랜저 인과관계 분석
# ============================================================

def run_granger_analysis(df):
    print("\n[STEP 6] 그랜저 인과관계 분석 (칸티용 효과 실증)")
    max_lag = CONFIG["GRANGER_MAX_LAG"]

    # ★ v4: M2_YoY 추가
    causes = [c for c in [
        "FedRate_Change", "Real_Rate", "QE_Size",
        "DXY_Change", "M2_YoY", "Monetary_Ease_Index"
    ] if c in df.columns]

    effects = [c for c in [
        "Gold_LogReturn", "WTI_LogReturn",
        "SP500_LogReturn", "CaseShiller_LogReturn", "CPI_LogReturn"
    ] if c in df.columns]

    lag_t  = pd.DataFrame(index=causes, columns=effects, dtype=float)
    pval_t = pd.DataFrame(index=causes, columns=effects, dtype=float)
    rows   = []

    for cause in causes:
        for effect in effects:
            try:
                data = df[[cause, effect]].dropna()
                if len(data) < max_lag + 5:
                    continue
                res      = grangercausalitytests(
                    data, maxlag=max_lag, verbose=False)
                best_lag = min(
                    res, key=lambda l: res[l][0]["ssr_ftest"][1])
                pval     = res[best_lag][0]["ssr_ftest"][1]
                sig = "✓" if pval < 0.05 else "✗"
                print(f"  {sig} {cause:22s} → {effect:25s} "
                      f"시차={best_lag:2d}개월  p={pval:.4f}")
                lag_t.loc[cause, effect]  = best_lag
                pval_t.loc[cause, effect] = pval
                rows.append({"cause": cause, "effect": effect,
                             "best_lag": best_lag, "p_value": pval,
                             "significant": pval < 0.05})
            except Exception:
                pass

    if not lag_t.dropna(how="all").empty:
        fig, axes = plt.subplots(1, 2, figsize=(22, 7))
        sns.heatmap(lag_t.astype(float), annot=True, fmt=".0f",
                    cmap="YlOrRd", ax=axes[0],
                    cbar_kws={"label": "최적 시차(월)"})
        axes[0].set_title(
            "그랜저 인과관계 최적 시차\n(M2 YoY 포함 v4)",
            fontsize=13, fontweight="bold")
        sns.heatmap(pval_t.astype(float), annot=True, fmt=".3f",
                    cmap="RdYlGn_r", ax=axes[1], vmin=0, vmax=0.1,
                    cbar_kws={"label": "p-value"})
        axes[1].set_title(
            "그랜저 인과관계 p-value\n(< 0.05 = 유의)",
            fontsize=13, fontweight="bold")
        plt.tight_layout()
        plt.savefig(f"{CONFIG['OUT_DIR']}/granger_heatmap.png",
                    dpi=150, bbox_inches="tight")
        plt.close()
        print(f"  ✓ 히트맵 저장")

    return pd.DataFrame(rows), lag_t


# ============================================================
# SECTION 8 : 칸티용 효과 시각화
# ============================================================

def plot_cantillon_path(df, lag_table=None):
    nodes = {
        "통화 완화\n환경":       (0.05, 0.50),
        "금\n(Gold)":            (0.30, 0.85),
        "WTI\n(원유)":           (0.30, 0.55),
        "S&P500\n(주식)":        (0.30, 0.25),
        "부동산\n(Case-Shiller)":(0.62, 0.70),
        "CPI\n(종착점)":         (0.90, 0.50),
    }
    edges = [
        ("통화 완화\n환경","금\n(Gold)",
         "royalblue","t+10~22개월","★"),
        ("통화 완화\n환경","WTI\n(원유)",
         "royalblue","t+1~4개월","★"),
        ("통화 완화\n환경","S&P500\n(주식)",
         "royalblue","t+1~18개월","★"),
        ("금\n(Gold)","부동산\n(Case-Shiller)",
         "darkorange","t+9~15개월",""),
        ("WTI\n(원유)","부동산\n(Case-Shiller)",
         "darkorange","t+6~12개월",""),
        ("금\n(Gold)","CPI\n(종착점)",
         "crimson","t+12~24개월",""),
        ("WTI\n(원유)","CPI\n(종착점)",
         "crimson","t+3~5개월",""),
        ("부동산\n(Case-Shiller)","CPI\n(종착점)",
         "crimson","t+11개월",""),
        ("S&P500\n(주식)","CPI\n(종착점)",
         "purple","t+24개월",""),
    ]

    fig, ax = plt.subplots(figsize=(15, 9))
    ax.set_xlim(-0.05,1.0); ax.set_ylim(-0.05,1.0)
    ax.axis("off"); ax.set_facecolor("#f8f9fa")
    ax.set_title(
        "칸티용 효과(Cantillon Effect) 자산 가격 전이 경로\n"
        "통화 완화 환경 → 자산군별 반응 시차  (v4 — M2 YoY 포함)",
        fontsize=13, fontweight="bold", pad=20
    )

    for src, tgt, color, label, star in edges:
        x0,y0 = nodes[src]; x1,y1 = nodes[tgt]
        ax.annotate("", xy=(x1,y1), xytext=(x0,y0),
                    arrowprops=dict(arrowstyle="-|>", color=color,
                                   lw=2.0,
                                   connectionstyle="arc3,rad=0.08"))
        ax.text((x0+x1)/2,(y0+y1)/2+0.02,f"{star}{label}",
                ha="center",va="bottom",fontsize=8,
                color=color,fontweight="bold" if star else "normal")

    color_map = {
        "통화 완화\n환경":        "#3498db",
        "금\n(Gold)":             "#f1c40f",
        "WTI\n(원유)":            "#e67e22",
        "S&P500\n(주식)":         "#2ecc71",
        "부동산\n(Case-Shiller)": "#e74c3c",
        "CPI\n(종착점)":          "#9b59b6",
    }
    for name,(x,y) in nodes.items():
        ax.add_patch(plt.Circle((x,y),0.085,
                                color=color_map.get(name,"lightskyblue"),
                                ec="white",lw=2,zorder=3,alpha=0.9))
        ax.text(x,y,name,ha="center",va="center",
                fontsize=8,fontweight="bold",zorder=4,color="white")

    legend_patches = [
        mpatches.Patch(color="royalblue",  label="통화환경→자산(1차)"),
        mpatches.Patch(color="darkorange", label="자산→부동산(2차)"),
        mpatches.Patch(color="crimson",    label="자산→CPI(최종)"),
        mpatches.Patch(color="purple",     label="주식→CPI(간접)"),
    ]
    ax.legend(handles=legend_patches, loc="lower right",
              fontsize=9, framealpha=0.9)

    plt.tight_layout()
    path = f"{CONFIG['OUT_DIR']}/cantillon_path.png"
    plt.savefig(path, dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  ✓ 칸티용 전이경로 맵 저장")


def plot_m2_vs_assets(df):
    """★ v4 신규: M2 YoY vs 각 자산 YoY 비교 시각화"""
    pairs = [
        ("M2_YoY", "Gold_YoY",        "M2 YoY vs 금 YoY"),
        ("M2_YoY", "WTI_YoY",         "M2 YoY vs WTI YoY"),
        ("M2_YoY", "SP500_YoY",       "M2 YoY vs S&P500 YoY"),
        ("M2_YoY", "CaseShiller_YoY", "M2 YoY vs 부동산 YoY"),
    ]
    fig = make_subplots(rows=2, cols=2,
                        subplot_titles=[p[2] for p in pairs])
    pos = [(1,1),(1,2),(2,1),(2,2)]
    pal = [("royalblue","gold"),("royalblue","orangered"),
           ("royalblue","green"),("royalblue","brown")]

    for (src,tgt,_),(r,c),(c1,c2) in zip(pairs,pos,pal):
