def plot_money_vs_assets(df):
    pairs = [
        ("M2_YoY", "Gold_YoY",    "M2 vs 금"),
        ("M2_YoY", "WTI_Oil_YoY", "M2 vs WTI"),
        ("M2_YoY", "Wheat_YoY",   "M2 vs 밀"),
        ("CPI_YoY","PPI_YoY",     "CPI vs PPI"),
    ]
    fig = make_subplots(rows=2, cols=2,
                        subplot_titles=[p[2] for p in pairs])
    pos = [(1,1),(1,2),(2,1),(2,2)]
    pal = [("royalblue","gold"),("royalblue","black"),
           ("royalblue","green"),("orangered","tomato")]

    for (src,tgt,_), (r,c), (c1,c2) in zip(pairs, pos, pal):
        if src in df.columns:
            fig.add_trace(go.Scatter(x=df.index,y=df[src],name=src,
                                     line=dict(color=c1)),row=r,col=c)
        if tgt in df.columns:
            fig.add_trace(go.Scatter(x=df.index,y=df[tgt],name=tgt,
                                     line=dict(color=c2)),row=r,col=c)

    fig.update_layout(title="통화량 vs 자산 가격 전이 대시보드 (v2)",
                      height=700, template="plotly_white")
    path = f"{CONFIG['OUT_DIR']}/dashboard.html"
    fig.write_html(path)
    print(f"  ✓ 대시보드 저장: {path}")


def plot_transmission_map():
    nodes = {
        "M2 통화량":          (0.00, 0.50),
        "귀금속\n(Gold/Silver)": (0.28, 0.80),
        "에너지\n(WTI/Gas)":  (0.28, 0.50),
        "원자재\n(Copper)":   (0.28, 0.20),
        "농산물\n(밀/옥수수)": (0.58, 0.75),
        "제조·운송비":        (0.58, 0.45),
        "건설비용":           (0.58, 0.15),
        "CPI\n(소비자물가)":  (0.88, 0.55),
        "주식섹터\n(에너지/소재)":(0.88, 0.85),
    }
    edges = [
        ("M2 통화량","귀금속\n(Gold/Silver)","royalblue","t+6~9개월"),
        ("M2 통화량","에너지\n(WTI/Gas)","royalblue","t+8~12개월"),
        ("M2 통화량","원자재\n(Copper)","royalblue","t+6개월"),
        ("귀금속\n(Gold/Silver)","농산물\n(밀/옥수수)","darkorange","t+3~6개월"),
        ("에너지\n(WTI/Gas)","농산물\n(밀/옥수수)","darkorange","t+3개월"),
        ("에너지\n(WTI/Gas)","제조·운송비","darkorange","t+2~4개월"),
        ("원자재\n(Copper)","건설비용","darkorange","t+3개월"),
        ("농산물\n(밀/옥수수)","CPI\n(소비자물가)","crimson","t+1~3개월"),
        ("제조·운송비","CPI\n(소비자물가)","crimson","t+1~2개월"),
        ("귀금속\n(Gold/Silver)","주식섹터\n(에너지/소재)","seagreen","즉각~t+3개월"),
    ]
    fig, ax = plt.subplots(figsize=(14, 8))
    ax.set_xlim(-0.1,1.0); ax.set_ylim(-0.05,1.0)
    ax.axis("off"); ax.set_facecolor("#fafafa")
    ax.set_title("통화량 → 자산군 가격 전이 경로 (Cantillon Effect)",
                 fontsize=14, fontweight="bold", pad=15)
    for src,tgt,color,label in edges:
        x0,y0=nodes[src]; x1,y1=nodes[tgt]
        ax.annotate("", xy=(x1,y1), xytext=(x0,y0),
                    arrowprops=dict(arrowstyle="-|>",color=color,
                                   lw=1.8,connectionstyle="arc3,rad=0.05"))
        ax.text((x0+x1)/2,(y0+y1)/2+0.02,label,
                ha="center",va="bottom",fontsize=7,color=color,alpha=0.9)
    for name,(x,y) in nodes.items():
        ax.add_patch(plt.Circle((x,y),0.075,color="lightskyblue",
                                ec="steelblue",lw=1.5,zorder=3))
        ax.text(x,y,name,ha="center",va="center",fontsize=8,
                fontweight="bold",zorder=4)
    plt.tight_layout()
    path = f"{CONFIG['OUT_DIR']}/transmission_map.png"
    plt.savefig(path,dpi=150,bbox_inches="tight")
    plt.close()
    print(f"  ✓ 전이 경로 맵 저장: {path}")


def plot_inflation_gauge(df):
    targets = ["CPI_YoY","PPI_YoY","M2_YoY","Gold_YoY","WTI_Oil_YoY"]
    targets = [c for c in targets if c in df.columns]
    z = {c: (df[c].iloc[-1] - df[c].mean()) / (df[c].std()+1e-8) for c in targets}

    fig, ax = plt.subplots(figsize=(10, 5))
    colors  = ["crimson" if v > 0 else "steelblue" for v in z.values()]
    bars    = ax.bar(z.keys(), z.values(), color=colors, alpha=0.85, edgecolor="white")
    ax.axhline(0, color="black", lw=1.2, ls="--")
    ax.axhline(1, color="orange", lw=1, ls=":", label="+1σ")
    ax.axhline(2, color="red",    lw=1, ls=":", label="+2σ")
    for bar,v in zip(bars,z.values()):
        ax.text(bar.get_x()+bar.get_width()/2,
                bar.get_height()+(0.05 if v>=0 else -0.12),
                f"{v:.2f}σ",ha="center",va="bottom",fontsize=9)
    ax.set_title("현재 인플레이션 위치 (장기 평균 대비 Z-score)",
                 fontsize=13, fontweight="bold")
    ax.set_ylabel("Z-score (σ)"); ax.legend(); ax.grid(True,alpha=0.3,axis="y")
    plt.tight_layout()
    path = f"{CONFIG['OUT_DIR']}/inflation_position.png"
    plt.savefig(path,dpi=150,bbox_inches="tight")
    plt.close()
    print(f"  ✓ 인플레이션 게이지 저장: {path}")


def generate_report(df, all_metrics):
    rows_html = ""
    for name, m in all_metrics.items():
        dir_class = "good" if m.get("Dir_Acc",0) >= 75 else ("ok" if m.get("Dir_Acc",0) >= 65 else "bad")
        r2_class  = "good" if m.get("R2",0) > 0.5 else "bad"
        rows_html += f"""
        <tr>
          <td><b>{name}</b></td>
          <td>{m.get('RMSE','-'):.4f}</td>
          <td>{m.get('MAE','-'):.4f}</td>
          <td>{m.get('MAPE','-'):.2f}%</td>
          <td>{m.get('sMAPE','-'):.2f}%</td>
          <td class="{r2_class}">{m.get('R2','-'):.4f}</td>
          <td class="{dir_class}">{m.get('Dir_Acc','-'):.1f}%</td>
        </tr>"""

    html = f"""<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <title>통화량-자산 전이 분석 리포트 v2</title>
  <style>
    body  {{ font-family:'Segoe UI',Arial,sans-serif; margin:40px; background:#f4f6f9; }}
    h1    {{ color:#2c3e50; }}
    .card {{ background:white; border-radius:10px; padding:24px; margin:20px 0;
             box-shadow:0 2px 8px rgba(0,0,0,.08); }}
    table {{ width:100%; border-collapse:collapse; }}
    th    {{ background:#2980b9; color:white; padding:10px; text-align:center; }}
    td    {{ padding:9px; border:1px solid #dfe6e9; text-align:center; }}
    tr:nth-child(even) {{ background:#f0f3f7; }}
    .good {{ color:#27ae60; font-weight:bold; }}
    .ok   {{ color:#f39c12; font-weight:bold; }}
    .bad  {{ color:#e74c3c; }}
    .meta {{ color:#888; font-size:.9em; }}
    img   {{ max-width:100%; border-radius:6px; margin:8px 0; }}
    .badge{{ display:inline-block; background:#27ae60; color:white;
             padding:3px 10px; border-radius:12px; font-size:.85em; }}
  </style>
</head>
<body>
  <h1>📊 통화량 변화에 따른 자산군별 가격 전이 분석 리포트
      <span class="badge">v2 — 앙상블 업그레이드</span></h1>
  <p class="meta">생성: {datetime.now().strftime('%Y년 %m월 %d일 %H:%M')} &nbsp;|&nbsp;
     기간: {df.index[0].strftime('%Y.%m')} ~ {df.index[-1].strftime('%Y.%m')}</p>

  <div class="card">
    <h2>1. 모델 성능 비교 <small style="color:#888">(방향성 정확도 목표: 80%↑)</small></h2>
    <table>
      <tr><th>모델</th><th>RMSE</th><th>MAE</th><th>MAPE</th>
          <th>sMAPE</th><th>R²</th><th>방향성 정확도</th></tr>
      {rows_html}
    </table>
    <p style="color:#888;font-size:.85em">
      🟢 방향성 ≥75%  🟡 65~74%  🔴 &lt;65%
    </p>
  </div>

  <div class="card"><h2>2. 그랜저 인과관계</h2>
    <img src="granger_heatmap.png"></div>

  <div class="card"><h2>3. 전이 경로 맵</h2>
    <img src="transmission_map.png"></div>

  <div class="card"><h2>4. 인플레이션 위치</h2>
    <img src="inflation_position.png"></div>

  <div class="card"><h2>5. 모델 성능 비교 차트</h2>
    <img src="model_comparison.png"></div>
</body>
</html>"""

    path = f"{CONFIG['OUT_DIR']}/report_v2.html"
    with open(path, "w", encoding="utf-8") as f:
        f.write(html)
    print(f"  ✓ HTML 리포트 저장: {path}")


# ============================================================
# SECTION 18 : 메인 실행 파이프라인
# ============================================================

def main():
    print("=" * 62)
    print("  통화량-자산 가격 전이 분석  ★ v2 (앙상블 + 분류 모델)")
    print("  방향성 정확도 목표: 60% → 80%")
    print("=" * 62)

    # 한글 폰트
    system = platform.system()
    if system == "Windows":     plt.rcParams["font.family"] = "Malgun Gothic"
    elif system == "Darwin":    plt.rcParams["font.family"] = "AppleGothic"
    plt.rcParams["axes.unicode_minus"] = False

    # ── STEP 1~5 : 데이터 수집 → 피처 엔지니어링 ─────────────
    df_raw = load_all_data()
    df_raw.to_csv(f"{CONFIG['OUT_DIR']}/raw_data.csv")

    df = preprocess(df_raw)
    df = add_shock_dummies(df)
    df = build_features(df)
    df.to_csv(f"{CONFIG['OUT_DIR']}/processed_data.csv")

    # ── STEP 5 : 그랜저 인과관계 ─────────────────────────────
    causality_df = run_granger_analysis(df)
    if not causality_df.empty:
        causality_df.to_csv(f"{CONFIG['OUT_DIR']}/granger.csv", index=False)

    # ── STEP 6~13 : 자산별 모델 학습 ─────────────────────────
    target_map = {
        "Gold":    "Gold_LogReturn",
        "WTI_Oil": "WTI_Oil_LogReturn",
        "Wheat":   "Wheat_LogReturn",
    }

    shock_cols  = [c for c in df.columns if c.startswith("Shock_")]
    all_metrics = {}

    for asset_name, target_col in target_map.items():
        if target_col not in df.columns:
            print(f"\n    {target_col} 없음, 건너뜁니다.")
            continue

        print(f"\n{'='*62}")
        print(f"  ▶ 자산: {asset_name}  ({target_col})")
        print("=" * 62)

        # 피처 선택
        base_feats = (
            [c for c in df.columns if any(
                k in c for k in ["M2","M1","CPI","PPI","Fed_Rate",
                                  "Yield_Spread","Real_Rate","M1_M2_Ratio",
                                  "NegRealRate","TIPS_Signal"]
            ) and "lag" in c] +
            [c for c in df.columns if target_col.split("_")[0] in c
             and ("lag" in c or "RSI" in c or "MACD" in c
                  or "Mom" in c or "MA" in c or "EMA" in c)] +
            shock_cols
        )
        feat_cols = list(dict.fromkeys(
            [c for c in base_feats if c in df.columns and c != target_col]
        ))

        data  = df[[target_col] + feat_cols].dropna()
        if len(data) < CONFIG["MIN_TRAIN"] + 30:
            print(f"    데이터 부족 ({len(data)}개), 건너뜁니다.")
            continue

        X_all = data[feat_cols]
        y_all = data[target_col]

        n       = len(data)
        tr_end  = int(n * 0.70)
        val_end = int(n * 0.85)

        X_tr,  y_tr  = X_all.iloc[:tr_end],    y_all.iloc[:tr_end]
        X_val, y_val = X_all.iloc[tr_end:val_end], y_all.iloc[tr_end:val_end]
        X_te,  y_te  = X_all.iloc[val_end:],    y_all.iloc[val_end:]

        print(f"  학습: {len(X_tr)}  검증: {len(X_val)}  테스트: {len(X_te)}")

        # 스케일링
        sx = StandardScaler(); sy = StandardScaler()
        X_tr_s  = pd.DataFrame(sx.fit_transform(X_tr),  columns=feat_cols, index=X_tr.index)
        X_val_s = pd.DataFrame(sx.transform(X_val),     columns=feat_cols, index=X_val.index)
        X_te_s  = pd.DataFrame(sx.transform(X_te),      columns=feat_cols, index=X_te.index)
        y_tr_s  = sy.fit_transform(y_tr.values.reshape(-1,1)).flatten()
        y_val_s = sy.transform(y_val.values.reshape(-1,1)).flatten()
        y_te_s  = sy.transform(y_te.values.reshape(-1,1)).flatten()

        # ★ 피처 선택 (노이즈 제거)
        top_feats = select_top_features(X_tr_s, y_tr_s)
        X_tr_sel  = X_tr_s[top_feats];   X_val_sel = X_val_s[top_feats]
        X_te_sel  = X_te_s[top_feats]

        # ★ Optuna 튜닝
        best_params = optuna_tune_xgb(X_tr_sel, y_tr_s, X_val_sel, y_val_s)

        # ── XGBoost 회귀 ──────────────────────────────────────
        print(f"\n   XGBoost 회귀 학습")
        xgb_reg = train_xgboost_reg(X_tr_sel, y_tr_s, X_val_sel, y_val_s, best_params)
        xgb_reg_pred = sy.inverse_transform(
            xgb_reg.predict(X_te_sel).reshape(-1,1)).flatten()
        xgb_reg_m = compute_metrics(y_te.values, xgb_reg_pred)
        print_metrics(xgb_reg_m, f"{asset_name} - XGBoost 회귀")
        all_metrics[f"{asset_name}_XGB_Reg"] = xgb_reg_m

        # ── XGBoost 분류 ──────────────────────────────────────
        print(f"\n   XGBoost 분류 (방향성 직접 최적화)")
        xgb_clf = train_xgboost_clf(X_tr_sel, y_tr_s, X_val_sel, y_val_s)
        clf_probs     = xgb_clf.predict_proba(X_te_sel)[:, 1]
        clf_dir_acc   = compute_ensemble_direction_accuracy(y_te.values, clf_probs)
        print(f"    ✓ XGBoost 분류 방향성 정확도: {clf_dir_acc:.1f}%")

        # ── LightGBM 회귀 ─────────────────────────────────────
        print(f"\n   LightGBM 회귀 학습")
        lgb_reg = train_lgb_reg(X_tr_sel, y_tr_s, X_val_sel, y_val_s)
        lgb_reg_pred = sy.inverse_transform(
            lgb_reg.predict(X_te_sel).reshape(-1,1)).flatten()
        lgb_reg_m = compute_metrics(y_te.values, lgb_reg_pred)
        print_metrics(lgb_reg_m, f"{asset_name} - LightGBM 회귀")
        all_metrics[f"{asset_name}_LGB_Reg"] = lgb_reg_m

        # ── LightGBM 분류 ─────────────────────────────────────
        print(f"\n   LightGBM 분류")
        lgb_clf = train_lgb_clf(X_tr_sel, y_tr_s, X_val_sel, y_val_s)
        lgb_clf_probs = lgb_clf.predict_proba(X_te_sel)[:, 1]

        # ── ★ 앙상블 (핵심: 회귀+분류 결합) ──────────────────
        print(f"\n  🔗 앙상블 예측 (회귀 + 분류 결합)")
        ens_preds, ens_probs = ensemble_predict(
            reg_models=[xgb_reg, lgb_reg],
            clf_models=[xgb_clf, lgb_clf],
            X=X_te_sel,
            y_scaler=sy
        )
        ens_m = compute_metrics(y_te.values, ens_preds)
        print_metrics(ens_m, f"{asset_name} - 앙상블 (최종)")
        all_metrics[f"{asset_name}_Ensemble"] = ens_m

        # ── SHAP 분석 ─────────────────────────────────────────
        run_shap(xgb_reg, X_te_sel, asset_name, "XGB_Reg")

        # ── Walk-forward 백테스팅 ─────────────────────────────
        print(f"\n   Walk-forward 백테스팅: {asset_name}")
        bt = walk_forward(X_tr_sel,
                          pd.Series(y_tr_s, index=X_tr_sel.index))
        plot_backtest(bt, asset_name)
        all_metrics[f"{asset_name}_WF_Ensemble"] = bt["avg_metrics"]

        # ── Bidirectional GRU ─────────────────────────────────
        feat_deep = top_feats[:25]   # 딥러닝은 25개 피처로 제한
        lb = CONFIG["LOOKBACK"]
        X_deep = np.vstack([X_tr_s[feat_deep].values,
                            X_val_s[feat_deep].values])
        y_deep = np.concatenate([y_tr_s, y_val_s])

        if len(X_deep) > lb + 30:
            print(f"\n   Bidirectional GRU 학습: {asset_name}")
            Xseq, yseq = create_sequences(X_deep, y_deep, lb)
            sp = int(len(Xseq) * 0.85)
            gru, hist = train_bigru(Xseq[:sp], yseq[:sp], Xseq[sp:], yseq[sp:])

            # GRU 학습 곡선
            fig, axes = plt.subplots(1, 2, figsize=(12, 4))
            axes[0].plot(hist.history["loss"],     label="Train", color="steelblue")
            axes[0].plot(hist.history["val_loss"], label="Val",   color="tomato")
            axes[0].set_title(f"{asset_name} BiGRU Loss"); axes[0].legend()
            axes[1].plot(hist.history["mae"],      label="Train", color="steelblue")
            axes[1].plot(hist.history["val_mae"],  label="Val",   color="tomato")
            axes[1].set_title(f"{asset_name} BiGRU MAE"); axes[1].legend()
            plt.tight_layout()
            plt.savefig(f"{CONFIG['OUT_DIR']}/bigru_{asset_name}_history.png",
                        dpi=150, bbox_inches="tight")
            plt.close()

            # GRU 테스트 예측
            X_te_deep = np.vstack([X_tr_s[feat_deep].values[-lb:],
                                   X_te_s[feat_deep].values])
            if len(X_te_deep) > lb:
                Xseq_te, yseq_te = create_sequences(
                    X_te_deep,
                    np.concatenate([y_tr_s[-lb:], y_te_s]),
                    lb
                )
                gru_raw  = gru.predict(Xseq_te, verbose=0).flatten()
                gru_pred = sy.inverse_transform(gru_raw.reshape(-1,1)).flatten()
                gru_act  = sy.inverse_transform(yseq_te.reshape(-1,1)).flatten()
                gru_m    = compute_metrics(gru_act, gru_pred)
                print_metrics(gru_m, f"{asset_name} - BiGRU")
                all_metrics[f"{asset_name}_BiGRU"] = gru_m

    # ── 전체 모델 비교 ────────────────────────────────────────
    print("\n[최종] 전체 모델 성능 비교")
    if all_metrics:
        compare_all_models(all_metrics)

    # ── 대시보드 & 리포트 ─────────────────────────────────────
    print("\n[최종] 시각화 및 리포트 생성")
    plot_money_vs_assets(df)
    plot_transmission_map()
    plot_inflation_gauge(df)
    generate_report(df, all_metrics)

    print("\n" + "=" * 62)
    print("  v2 파이프라인 완료!")
    print(f"  결과: {CONFIG['OUT_DIR']}/report_v2.html")
    print("=" * 62)

    return df, all_metrics


# ── 실행 진입점 ──────────────────────────────────────────────
if __name__ == "__main__":
    df_result, metrics_result = main()
